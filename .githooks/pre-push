#!/usr/bin/env bash
# Pre-push gate: mirror what CI enforces so main never goes red.
# Enabled via: git config core.hooksPath .githooks
# Bypass (emergencies only): git push --no-verify
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "pre-push gate: pnpm lint && pnpm typecheck && pnpm test"
pnpm lint && pnpm typecheck && pnpm test
